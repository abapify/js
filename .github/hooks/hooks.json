{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/approve-workflows.sh",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/approve-workflows.sh",
        "cwd": ".",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": ".github/hooks/scripts/log-tool-calls.sh",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/print-tool-log.sh",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
