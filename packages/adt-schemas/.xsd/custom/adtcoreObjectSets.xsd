<?xml version="1.0" encoding="UTF-8"?>
<!--
  ADT Core Object Sets Extension
  
  Extends the adtcore namespace with objectSets types that SAP uses
  in AUnit and ATC request bodies but doesn't publish in the official XSD.
  
  This XSD shares targetNamespace with adtcore so it contributes types
  to the same namespace. It imports adtcore for the objectReferences ref.
  
  Used by:
  - aunitRun.xsd (ref="adtcore:objectSets")
  - Potentially atcRun.xsd in the future
-->
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema"
    xmlns:adtcore="http://www.sap.com/adt/core"
    targetNamespace="http://www.sap.com/adt/core">

  <xsd:include schemaLocation="../sap/adtcore.xsd"/>

  <!-- Global element for namespace-qualified adtcore:objectSets -->
  <xsd:element name="objectSets" type="adtcore:AdtObjectSets"/>

  <xsd:complexType name="AdtObjectSets">
    <xsd:sequence>
      <xsd:element name="objectSet" type="adtcore:AdtObjectSet" minOccurs="0" maxOccurs="unbounded" form="unqualified"/>
    </xsd:sequence>
  </xsd:complexType>

  <xsd:complexType name="AdtObjectSet">
    <xsd:sequence>
      <xsd:element ref="adtcore:objectReferences" minOccurs="0" maxOccurs="1"/>
    </xsd:sequence>
    <xsd:attribute name="kind" type="xsd:string" form="unqualified"/>
  </xsd:complexType>

</xsd:schema>
