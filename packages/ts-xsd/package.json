{
  "name": "ts-xsd",
  "version": "0.1.6",
  "description": "Core XSD parser and builder - W3C XMLSchema 1:1 TypeScript representation",
  "type": "module",
  "types": "./dist/index.d.mts",
  "bin": {
    "ts-xsd": "./dist/codegen/cli.mjs"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./codegen/cli": "./dist/codegen/cli.mjs",
    "./generators": "./dist/generators/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "dependencies": {
    "@xmldom/xmldom": "*"
  }
}
