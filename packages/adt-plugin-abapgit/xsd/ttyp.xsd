<?xml version="1.0" encoding="UTF-8"?>
<!--
  abapGit TTYP (Table Type) Schema

  Defines the DD40V structure used in *.ttyp.xml files.
  Based on SAP DDIC table DD40V (table type header).

  Uses xs:redefine to extend AbapValuesType with TTYP-specific elements.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           targetNamespace="http://www.sap.com/abapxml"
           xmlns:asx="http://www.sap.com/abapxml"
           elementFormDefault="unqualified">

  <!-- Include types (brought into asx namespace) -->
  <xs:include schemaLocation="types/dd40v.xsd"/>

  <!-- Redefine AbapValuesType to include TTYP-specific elements -->
  <xs:redefine schemaLocation="asx.xsd">
    <xs:complexType name="AbapValuesType">
      <xs:complexContent>
        <xs:extension base="asx:AbapValuesType">
          <xs:sequence>
            <xs:element name="DD40V" type="asx:Dd40vType" minOccurs="0"/>
          </xs:sequence>
        </xs:extension>
      </xs:complexContent>
    </xs:complexType>
  </xs:redefine>

  <!-- Import abapGit root element -->
  <xs:import schemaLocation="abapgit.xsd"/>

</xs:schema>
